<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<GridPane fx:controller="com.example.denyconquer.ChooseColorController"
          xmlns:fx="http://javafx.com/fxml" alignment="center"
          hgap="10" vgap="10"
          stylesheets="@styles.css"
          id="gridPane">
    <padding><Insets top="20" right="40" bottom="30" left="40"/></padding>
    <columnConstraints>
        <ColumnConstraints minWidth="100" prefWidth="100"
                           maxWidth="100" halignment="RIGHT">
        </ColumnConstraints>
        <ColumnConstraints minWidth="100" prefWidth="100"
                           maxWidth="100" >
        </ColumnConstraints>
    </columnConstraints>
    <Label text="Select color" GridPane.columnIndex="0"
           GridPane.rowIndex="0" GridPane.columnSpan="2"
           GridPane.rowSpan="1" GridPane.halignment="CENTER" >
        <font>
            <Font name="Verdana" size="20" ></Font>
        </font>
        <GridPane.margin>
            <Insets top="20" right="0" bottom="20" left="0"></Insets>
        </GridPane.margin>
    </Label>

    <GridPane fx:id="colorGrid" hgap="10.0"  GridPane.columnIndex="0"
              GridPane.rowIndex="1" GridPane.columnSpan="2"
              GridPane.rowSpan="1" GridPane.halignment="CENTER">
        <columnConstraints>
            <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" maxWidth="30.0" minWidth="30.0" prefWidth="30.0" />
            <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" maxWidth="30.0" minWidth="30.0" prefWidth="30.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="35.0" valignment="CENTER" vgrow="SOMETIMES" prefHeight="35.0"/>
            <RowConstraints minHeight="30.0" valignment="CENTER" vgrow="SOMETIMES" prefHeight="30.0" />
        </rowConstraints>
        <GridPane.margin>
            <Insets left="50.0" />
        </GridPane.margin>
    </GridPane>

    <Label text="Chosen Colour:" GridPane.columnIndex="0"
           GridPane.rowIndex="3" >
    </Label>
    <Canvas fx:id="selectedColorCanvas" width="30.0" height="20.0" GridPane.columnIndex="1"
            GridPane.rowIndex="3">
        <HBox.margin>
            <Insets left="10.0" right="25.0" />
        </HBox.margin>
    </Canvas>

    <Button fx:id="registerColorButton" text="Confirm color"
            prefWidth="120" prefHeight="20"
            GridPane.columnIndex="0" GridPane.rowIndex="4"
            GridPane.columnSpan="2" GridPane.rowSpan="1"
            GridPane.halignment="CENTER"
            onMouseClicked="#registerColorButtonClicked" >
        <font>
            <Font size="12.0" />
        </font>
        <GridPane.margin>
            <Insets top="10" right="0" bottom="70" left="0"></Insets>
        </GridPane.margin>
    </Button>
    <Text fx:id="colorMessage" strokeType="OUTSIDE" strokeWidth="0.0" text="Already taken" visible="false"
          GridPane.columnIndex="0" GridPane.rowIndex="4"
          GridPane.columnSpan="2" GridPane.rowSpan="1"
          GridPane.halignment="CENTER">

    </Text>

    <Button fx:id="startGameButton" text="Start Game"
            prefWidth="150" prefHeight="30"
            GridPane.columnIndex="0" GridPane.rowIndex="4"
            GridPane.columnSpan="2" GridPane.rowSpan="1"
            GridPane.halignment="CENTER"
            onMouseClicked="#startGameButtonClicked"
            disable="true" mnemonicParsing="false">
        <font>
            <Font size="14.0" />
        </font>
        <GridPane.margin>
            <Insets top="110" right="0" bottom="10" left="0"></Insets>
        </GridPane.margin>
    </Button>

</GridPane>