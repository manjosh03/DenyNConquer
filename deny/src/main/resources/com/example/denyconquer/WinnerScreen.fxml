<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>

<GridPane fx:controller="com.example.denyconquer.WaitingStageController"
          xmlns:fx="http://javafx.com/fxml" alignment="center"
          hgap="10" vgap="10"
          stylesheets="@styles.css"
          id="gridPane">
    <padding><Insets top="20" right="40" bottom="30" left="40"/></padding>
    <columnConstraints>
        <ColumnConstraints minWidth="100" prefWidth="100"
                           maxWidth="100" halignment="RIGHT">
        </ColumnConstraints>
        <ColumnConstraints minWidth="100" prefWidth="100"
                           maxWidth="100" >
        </ColumnConstraints>
    </columnConstraints>
    <Label text="Game Ended" GridPane.columnIndex="0"
           GridPane.rowIndex="0" GridPane.columnSpan="2"
           GridPane.rowSpan="1" GridPane.halignment="CENTER" >
        <font>
            <Font name="Arial" size="24" ></Font>
        </font>
        <GridPane.margin>
            <Insets top="20" right="0" bottom="20" left="0"></Insets>
        </GridPane.margin>
    </Label>

    <Label text="Winner" GridPane.columnIndex="0"
           GridPane.rowIndex="1" >
        <font>
            <Font name="Arial" size="18" ></Font>
        </font>
    </Label>

    <Text fx:id="WinnerColorWin" GridPane.columnIndex="1"
          GridPane.rowIndex="1"  text="Winner Color" />

    <Label text="Points = " GridPane.columnIndex="0"
           GridPane.rowIndex="2" >
        <font>
            <Font name="Arial" size="18" ></Font>
        </font>
    </Label>

    <Text fx:id="WinnerPointsWin" GridPane.columnIndex="1"
          GridPane.rowIndex="2"  text="0 " />

</GridPane>

